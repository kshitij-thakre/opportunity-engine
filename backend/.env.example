# Opportunity Engine Backend Configurations

# Database variables
POSTGRES_USER=opportunity_engine
POSTGRES_PASSWORD=opportunity_engine
POSTGRES_DB=opportunity_engine

# Database Connection URL (used by SQLAlchemy/AsyncPG)
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=postgresql://opportunity_engine:opportunity_engine@db:5432/opportunity_engine
